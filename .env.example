# Operational env vars consumed by memo-discord-bot.
# Per memo-docs/standards/secrets.md: variable names only, no values committed.
# Real values for secrets are managed centrally by the team — request the
# current value from the operator inventory rather than guessing or reusing.
#
# Local dev: copy this file to `.env`, fill in values, and never commit `.env`
# (`.gitignore` already excludes it).

# ---------------------------------------------------------------------------
# Logging & runtime identity (non-secret)
# ---------------------------------------------------------------------------

# what:  zerolog floor — trace / debug / info / warn / error. defaults to info.
# where: not a secret; set locally as needed.
# when:  local debugging.
LOG_LEVEL=

# what:  prod | dev. controls env-gated behavior and the `env` field on every log line.
# where: not a secret; injected per environment by orchestrator (compose / k8s).
# when:  optional locally; falls back to "dev" if unset.
MEMO_ENV=

# what:  git tag for this build. baked into /status `version` and JSON log `version` field.
# where: not a secret; CI injects via docker build-arg.
# when:  only set locally if you want /status to report a real tag instead of "dev".
MEMO_VERSION=

# what:  short commit SHA for this build. baked into /status `build` and JSON log `build` field.
# where: not a secret; CI injects via docker build-arg.
# when:  same as MEMO_VERSION; falls back to "unknown".
MEMO_BUILD=

# ---------------------------------------------------------------------------
# Secrets — never commit real values
# ---------------------------------------------------------------------------

# what:  Discord bot token (gateway authentication).
# where: managed centrally — request from the operator secret inventory.
# when:  required for the bot to connect to Discord; discord-gateway is a
#        /status/ready critical check.
DISCORD_BOT_TOKEN=

# what:  Postgres DSN, e.g. postgres://user:pass@host:5432/dbname.
# where: managed centrally — request from the operator secret inventory.
# when:  required for the bot to start; DB ping is a /status/ready critical check.
DATABASE_URL=

# what:  Redis URL, e.g. redis://:pass@host:6379/0.
# where: managed centrally — request from the operator secret inventory.
# when:  required for the bot to start; Redis ping is a /status/ready critical check.
REDIS_URL=

# what:  Bearer token authenticating the GitHub Actions deploy-status webhook
#        (POST /webhook/gha, `Authorization: Bearer <token>`). Must match the
#        value set by the calling GHA workflow.
# where: managed centrally — request from the operator secret inventory.
# when:  required if exercising the deploy-status notification flow locally.
GHA_WEBHOOK_TOKEN=

# what:  HMAC shared secret for verifying GitHub repo-event webhooks
#        (POST /webhook/github, `X-Hub-Signature-256` header). Must match the
#        secret configured on the GitHub webhook itself.
# where: managed centrally — request from the operator secret inventory.
# when:  required if exercising GitHub repo-event handling locally.
GITHUB_WEBHOOK_SECRET=
